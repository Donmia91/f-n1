# Server Configuration
PORT=8787
NODE_ENV=development

# X (Twitter) OAuth Configuration
X_API_KEY=YOUR_X_API_KEY
X_API_SECRET=YOUR_X_API_SECRET
X_CALLBACK_URL=http://localhost:8787/api/social/oauth/x/callback
X_OAUTH_SCOPES=users.read tweet.read tweet.write offline.access

# Encryption Key (for token storage)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-key-here

# Database
DB_PATH=./data/fn1.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Sentry Observability Integration
# Get auth token from https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=

# ─── Meta / Instagram (Instagram Graph API) ──────────────────────────────────
# Create your app at https://developers.facebook.com
# Required permissions: instagram_basic, instagram_content_publish,
#   instagram_manage_comments, instagram_manage_insights,
#   pages_show_list, pages_read_engagement
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
# Add this exact URI to your Meta app's OAuth Redirect URIs:
META_REDIRECT_URI=http://localhost:8787/api/social/instagram/oauth/callback

# ─── OpenAI (Growth Ops Agent) ───────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
GROWTH_OPS_AGENT_MODEL=gpt-4o
REASONING_PRIMARY_PROVIDER=openai
REASONING_OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Grafana Observability Integration
# Service account token from https://your-grafana/org/serviceaccounts
GRAFANA_URL=https://your-grafana-instance.com
GRAFANA_API_KEY=
# Optional: pin to a specific dashboard UID shown in the drawer
GRAFANA_DASHBOARD_UID=
